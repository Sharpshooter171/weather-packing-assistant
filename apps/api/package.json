{
  "name": "@weather-packing-assistant/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "echo \"API tests not implemented yet\"",
    "lint": "echo \"API lint not implemented yet\"",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
